# ============================================================
# Ocean-Agent-SDK multi-provider env template
# Copy to .env and keep only the provider block you actually use.
# ============================================================

KODE_API_SECRET=your-secret-key
KODE_API_PORT=8788
SKILLS_DIR=/home/lz/Ocean-Agent-SDK/.skills
PYTHON3=/home/lz/miniconda3/envs/pytorch/bin/python

# Optional: test-client.ts will fall back to KODE_API_PORT if omitted.
# KODE_API_URL=http://localhost:8788

# Optional: set proxy for upstream model requests.
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890

# ============================================================
# Provider 1: OpenAI and OpenAI-compatible APIs
# DeepSeek / GLM / Qwen / Minimax / OpenRouter / compatible gateways
# ============================================================

# KODE_MODEL_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL_ID=gpt-5.4
# Compatibility-first default. Only switch to responses if your upstream
# explicitly supports the Responses API and reasoning fields.
# OPENAI_API_MODE=chat
#
# Optional reasoning config for Responses API:
# OPENAI_API_MODE=responses
# OPENAI_REASONING_EFFORT=medium
# OPENAI_REASONING_TRANSPORT=text

# Example compatible endpoints:
# DeepSeek:   OPENAI_BASE_URL=https://api.deepseek.com/v1
# GLM:        OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# Qwen:       OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OpenRouter: OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ============================================================
# Provider 2: Anthropic / Claude-compatible APIs
# ============================================================

# KODE_MODEL_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL_ID=claude-sonnet-4-5-20250929

# ============================================================
# Provider 3: Gemini
# ============================================================

# KODE_MODEL_PROVIDER=gemini
# GOOGLE_API_KEY=your-google-api-key
# GEMINI_MODEL_ID=gemini-3-flash
# Optional custom endpoint:
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com
